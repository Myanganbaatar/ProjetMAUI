<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BarsboldApp.Views.AjoutPage"
             Title="Add"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#121212}">
    
    <ScrollView>
        <VerticalStackLayout
            Padding="24,32,24,32"
            Spacing="20">

            <!-- Titre de la page -->
            <Label
                Text="Ajouter un élément"
                FontSize="26"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}"
                Margin="0,0,0,32" />

            <!-- Champ Titre -->
            <VerticalStackLayout Spacing="10">
                <Label
                    Text="Titre"
                    FontSize="13"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#3A3A3C, Dark=#BBB}" />

                <Frame
                    Padding="16,12"
                    HasShadow="False"
                    BorderColor="Transparent"
                    BackgroundColor="{AppThemeBinding Light=#F0F0F5, Dark=#1E1E1E}"
                    CornerRadius="15">
                    <Entry
                        x:Name="TitreEntry"
                        Text="{Binding Titre}"
                        Placeholder="Entrez le titre"
                        PlaceholderColor="{AppThemeBinding Light=#B0B0B5, Dark=#666}"
                        FontSize="16"
                        TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}"
                        BackgroundColor="Transparent" />
                </Frame>
            </VerticalStackLayout>

            <!-- Champ Description -->
            <VerticalStackLayout Spacing="10">
                <Label
                    Text="Description"
                    FontSize="13"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#3A3A3C, Dark=#BBB}" />

                <Frame
                    Padding="16,12"
                    HasShadow="False"
                    BorderColor="Transparent"
                    BackgroundColor="{AppThemeBinding Light=#F0F0F5, Dark=#1E1E1E}"
                    CornerRadius="15">
                    <Editor
                        x:Name="DescriptionEditor"
                        Text="{Binding Description}"
                        Placeholder="Entrez la description"
                        PlaceholderColor="{AppThemeBinding Light=#B0B0B5, Dark=#666}"
                        FontSize="16"
                        TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}"
                        BackgroundColor="Transparent"
                        HeightRequest="100"
                        AutoSize="TextChanges" />
                </Frame>
            </VerticalStackLayout>

            <!-- Bouton Photo -->
            <Button
                Text="📷  Ajouter une photo"
                Command="{Binding ChoisirImageCommand}"
                BackgroundColor="{AppThemeBinding Light=#586B95, Dark=#3D4B68}"
                TextColor="White"
                CornerRadius="25"
                HeightRequest="50"
                FontSize="15"
                FontAttributes="Bold"
                Margin="0,8,0,0" />

            <!-- Zone d'aperçu Image -->
            <VerticalStackLayout Spacing="8">
                <!-- Message si aucune image -->
                <Label
                    Text="Aucune image sélectionnée"
                    FontSize="12"
                    TextColor="{AppThemeBinding Light=#B0B0B5, Dark=#666}"
                    HorizontalOptions="Center"
                    Margin="0,8,0,0"
                    IsVisible="{Binding ImagePath, Converter={StaticResource InverseStringToBoolConverter}}" />

                <!-- Aperçu de l'image -->
                <Frame
                    Padding="0"
                    HasShadow="False"
                    BorderColor="Transparent"
                    BackgroundColor="Transparent"
                    CornerRadius="15"
                    HeightRequest="200"
                    IsVisible="{Binding ImagePath, Converter={StaticResource StringToBoolConverter}}">
                    <Image
                        x:Name="PreviewImage"
                        Source="{Binding ImagePath}"
                        Aspect="AspectFill" />
                </Frame>
            </VerticalStackLayout>

            <!-- Bouton Valider -->
            <Button
                x:Name="BtnAjouter"
                Text="Ajouter l'élément"
                Command="{Binding AjouterCommand}"
                BackgroundColor="{AppThemeBinding Light=#512BD4, Dark=#4021A8}"
                TextColor="White"
                CornerRadius="25"
                HeightRequest="50"
                FontSize="16"
                FontAttributes="Bold"
                Margin="0,24,0,0"
                Pressed="OnAjouterPressed"
                Released="OnAjouterReleased" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

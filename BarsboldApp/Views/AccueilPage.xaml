<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BarsboldApp.Views.AccueilPage"
             Title="Accueil">
    <ScrollView>
        <VerticalStackLayout
            Padding="20,10,20,20"
            Spacing="10"
            VerticalOptions="Start">

            <Image
                Source="logos.svg"
                HeightRequest="120"
                WidthRequest="120"
                HorizontalOptions="Center" />

            <Label
                Text="{Binding MainTitle}"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center" />

            <Label
                Text="{Binding SubTitle}"
                FontSize="16"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center" />

            <Grid Margin="0,5,0,0"
                  ColumnDefinitions="*, *"
                  HorizontalOptions="Center"
                  WidthRequest="300">
                <Image Grid.Column="0"
                       Source="airplane.png"
                       HeightRequest="100"
                       WidthRequest="100"
                       Aspect="AspectFit" />
                <Image Grid.Column="1"
                       Source="location.png"
                       HeightRequest="100"
                       WidthRequest="100"
                       Aspect="AspectFit" />
            </Grid>

            <CarouselView x:Name="CarouselCountries"
                          ItemsSource="{Binding CountryImages}"
                          HeightRequest="180"
                          Loop="True"
                          PeekAreaInsets="0">
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeThickness="0"
                                Margin="5,0"
                                StrokeShape="RoundRectangle 15">
                            <Image Source="{Binding .}"
                                   Aspect="AspectFill"
                                   HeightRequest="180" />
                        </Border>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <Button
                x:Name="GifBtn"
                Text="Voir l'animation"
                Clicked="OnGifButtonClicked"
                HorizontalOptions="Fill"
                BackgroundColor="#0078D7"
                TextColor="White"
                CornerRadius="10"
                Margin="0,10,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BarsboldApp.Views.AccueilPage"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False"
             Title="Acceuil">
    
    <Grid RowDefinitions="*,Auto">
        
        <!-- Contenu principal -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout
                Padding="30,20,30,20"
                Spacing="25"
                VerticalOptions="Center">

                <!-- Titre principal -->
                <Label
                    Text="Explorateur de Pays"
                    FontSize="28"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    TextColor="#1A1A1A"
                    Margin="0,10,0,5" />

                <!-- Sous-titre -->
                <Label
                    Text="Le monde à portée de main"
                    FontSize="16"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    TextColor="#6B6B6B"
                    Margin="0,0,0,30" />

                <!-- Icônes stylisées (globe avec avion et carte avec épingles) -->
                <Grid Margin="0,20,0,20"
                      ColumnDefinitions="*, *"
                      HorizontalOptions="Center"
                      WidthRequest="280">

                    <Image Grid.Column="0"
                           Source="airplane.png"
                           HeightRequest="100" 
                           WidthRequest="100"
                           Aspect="AspectFit"
                           HorizontalOptions="Center" />

                    <Image Grid.Column="1"
                           Source="location.png"
                           HeightRequest="100"
                           WidthRequest="100"
                           Aspect="AspectFit"
                           HorizontalOptions="Center" />
                </Grid>

                <!-- Drapeau français -->
                <Border StrokeThickness="1"
                        Stroke="#E0E0E0"
                        StrokeShape="RoundRectangle 8"
                        HeightRequest="120"
                        WidthRequest="180"
                        HorizontalOptions="Center"
                        Margin="0,10,0,25">
                    <CarouselView x:Name="CarouselCountries"
                                  ItemsSource="{Binding CountryImages}"
                                  Loop="True"
                                  PeekAreaInsets="0">
                        <CarouselView.ItemTemplate>
                            <DataTemplate>
                                <Image Source="{Binding .}"
                                       Aspect="AspectFill" />
                            </DataTemplate>
                        </CarouselView.ItemTemplate>
                    </CarouselView>
                </Border>

                <!-- Bouton bleu arrondi -->
                <Button
                    x:Name="GifBtn"
                    Text="Voir l'animation"
                    Clicked="OnGifButtonClicked"
                    HorizontalOptions="Fill"
                    BackgroundColor="#0078D7"
                    TextColor="White"
                    CornerRadius="25"
                    HeightRequest="50"
                    FontSize="16"
                    FontAttributes="Bold"
                    Margin="20,15,20,30" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Barre de navigation en bas -->
        <Grid Grid.Row="1"
              BackgroundColor="#F8F8F8"
              Padding="10,8,10,8"
              ColumnDefinitions="*,*,*,*"
              HeightRequest="70">
            
           
            
        </Grid>
        
    </Grid>
    
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BarsboldApp.Views.PaysDetailPage"
             Title="{Binding Name}"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#121212}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">
            
            <Image Source="{Binding Media.Flag}"
                   HeightRequest="200"
                   Aspect="AspectFit" 
                   HorizontalOptions="Center" />

            <Label Text="{Binding Name}"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" 
                   TextColor="{AppThemeBinding Light=#512BD4, Dark=#7E57C2}"/>

            <Frame BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#1E1E1E}" 
                   Padding="20" CornerRadius="12" HasShadow="True" BorderColor="Transparent">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Informations détaillées" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}"/>
                    
                    <Label Text="{Binding Capital, StringFormat='🏙️ Capitale : {0}'}" 
                           FontSize="16" 
                           TextColor="{AppThemeBinding Light=#333, Dark=#BBB}"/>
                    <Label Text="{Binding Population, StringFormat='👥 Population : {0:N0} habitants'}" 
                           FontSize="16" 
                           TextColor="{AppThemeBinding Light=#333, Dark=#BBB}"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
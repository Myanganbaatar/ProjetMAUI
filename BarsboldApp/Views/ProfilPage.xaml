<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BarsboldApp.Views.ProfilPage"
             Title="Profil"
             BackgroundColor="White">
    
    <ScrollView>
        <VerticalStackLayout Spacing="10">
            
            <!-- SECTION : MES ÉLÉMENTS (Collègue) -->
            <VerticalStackLayout x:Name="ItemsSection" BackgroundColor="White">
                <VerticalStackLayout Padding="20,20,20,10" Spacing="5">
                    <Label Text="Mes Éléments" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#333"/>
                    <Label Text="Liste des éléments ajoutés" FontSize="12" HorizontalOptions="Center" TextColor="#888"/>
                </VerticalStackLayout>

                <VerticalStackLayout Padding="10">
                    <VerticalStackLayout IsVisible="{Binding IsListEmpty}" Padding="20" Spacing="10" HorizontalOptions="Center">
                        <Label Text="📋" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="Aucun élément ajouté" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- BindableLayout is safer for scrolling inside a ScrollView if list is not huge -->
                    <!-- But let's use CollectionView with a fixed Height if we must. -->
                    <!-- Using CollectionView with HeightRequest for stability -->
                    <CollectionView ItemsSource="{Binding Items}" 
                                    SelectionMode="None"
                                    HeightRequest="300" 
                                    IsVisible="{Binding IsNotEmpty}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="5" Padding="5" CornerRadius="10">
                                    <Label Text="{Binding Titre}" FontAttributes="Bold"/>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>
            
            <BoxView HeightRequest="2" Color="#EEE" Margin="10,5" />

            <!-- SECTION : PAYS (Vos ajouts) -->
            <VerticalStackLayout x:Name="PaysSection" Padding="10">
                <Label Text="🌎 Liste des Pays" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center" 
                       Margin="0,0,0,10"
                       TextColor="#512BD4"/>

                <!-- Indicateur de chargement -->
                <ActivityIndicator IsRunning="{Binding IsLoading}" 
                                   IsVisible="{Binding IsLoading}" 
                                   Color="#512BD4" 
                                   HorizontalOptions="Center" />

                <!-- CollectionView avec hauteur forcée pour éviter le bug de collapse -->
                <CollectionView ItemsSource="{Binding ListePays}" 
                                SelectionMode="Single" 
                                SelectionChanged="SurPaysSelectionne" 
                                HeightRequest="600"
                                Margin="0,5">
                    <CollectionView.EmptyView>
                        <Label Text="Aucun pays trouvé ou chargement en cours..." 
                               HorizontalOptions="Center" 
                               Margin="20" 
                               TextColor="Gray"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,5" Padding="15" CornerRadius="12" BorderColor="#EEE">
                                <StackLayout Orientation="Horizontal" Spacing="15">
                                    <Image Source="{Binding Media.Flag}" WidthRequest="50" HeightRequest="30" Aspect="AspectFill" />
                                    <Label Text="{Binding Name}" FontSize="16" VerticalOptions="Center" FontAttributes="Bold"/>
                                </StackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

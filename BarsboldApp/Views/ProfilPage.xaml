<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BarsboldApp.Views.ProfilPage"
             Title="Profil"
             BackgroundColor="White">
    
    <ScrollView>
        <VerticalStackLayout>
            
            <!-- SECTION : MES ÉLÉMENTS (Collègue) -->
            <VerticalStackLayout x:Name="ItemsSection">
                <VerticalStackLayout Padding="30,30,30,20" Spacing="8">
                    <Label Text="Mes Éléments" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#1A1A1A" />
                    <Label Text="Liste des éléments ajoutés" FontSize="14" HorizontalOptions="Center" TextColor="#6B6B6B" />
                </VerticalStackLayout>

                <StackLayout Padding="20,10,20,20">
                    <VerticalStackLayout IsVisible="{Binding IsListEmpty}" Padding="30" Spacing="15" VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="📋" FontSize="64" HorizontalOptions="Center" />
                        <Label Text="Aucun élément ajouté" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#6B6B6B" />
                        <Label Text="Utilisez l'onglet Ajout pour créer votre premier élément" FontSize="14" HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="#999999" />
                    </VerticalStackLayout>

                    <CollectionView ItemsSource="{Binding Items}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="1" Stroke="#E0E0E0" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="0" Margin="0,0,0,15">
                                    <Grid RowDefinitions="Auto,Auto,Auto" Padding="0">
                                        <Border Grid.Row="0" StrokeThickness="0" StrokeShape="RoundRectangle 12,12,0,0" HeightRequest="200">
                                            <Image Source="{Binding ImagePath}" Aspect="AspectFill" />
                                        </Border>
                                        <Label Grid.Row="1" Text="{Binding Titre}" FontSize="20" FontAttributes="Bold" TextColor="#1A1A1A" Margin="15,15,15,5" />
                                        <Label Grid.Row="2" Text="{Binding Description}" FontSize="14" TextColor="#6B6B6B" LineBreakMode="WordWrap" Margin="15,0,15,15" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>
            </VerticalStackLayout>
            
            <!-- Ligne de séparation -->
            <BoxView HeightRequest="1" Color="#E0E0E0" Margin="20,10" />

            <!-- SECTION : PAYS (Vos ajouts) -->
            <Grid RowDefinitions="Auto, *" x:Name="PaysSection" MinimumHeightRequest="300" Padding="0,10,0,20">
                <Label Grid.Row="0" Text="Liste des Pays" FontSize="24" FontAttributes="Bold" Margin="15" HorizontalOptions="Center"/>

                <CollectionView Grid.Row="1" ItemsSource="{Binding ListePays}" SelectionMode="Single" SelectionChanged="SurPaysSelectionne" Margin="10">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="5" Padding="10" CornerRadius="10" HasShadow="True">
                                <StackLayout Orientation="Horizontal" Spacing="15">
                                    <Image Source="{Binding Media.Flag}" WidthRequest="60" HeightRequest="40" Aspect="AspectFill" />
                                    <Label Text="{Binding Name}" FontSize="18" VerticalOptions="Center" FontAttributes="Bold"/>
                                </StackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

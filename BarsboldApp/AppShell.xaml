<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BarsboldApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:BarsboldApp.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="White"
    Shell.TabBarTitleColor="Gray"
    Shell.TabBarUnselectedColor="Gray"
    Shell.TabBarForegroundColor="#512BD4"
    Title="BarsboldApp">

    <TabBar>
        <ShellContent
            Title="Accueil"
            Icon="home_icon.png"
            ContentTemplate="{DataTemplate views:AccueilPage}"
            Route="AccueilPage" />

        <ShellContent
            Title="Profil"
            Icon="profile_icon.png"
            ContentTemplate="{DataTemplate views:ProfilPage}"
            Route="ProfilPage" />

        <ShellContent
            Title="Ajout"
            Icon="add_icon.png"
            ContentTemplate="{DataTemplate views:AjoutPage}"
            Route="AjoutPage" />

        <ShellContent
            Title="Paramètres"
            Icon="settings_icon.png"
            ContentTemplate="{DataTemplate views:ParametresPage}"
            Route="ParametresPage" />
    </TabBar>

</Shell>
